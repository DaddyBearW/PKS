@page "/"
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Товары</PageTitle>

<section class="grid">
    <div class="card">
        <h2>Список товаров</h2>

        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <p class="status-message">@statusMessage</p>
        }

        @if (isLoading)
        {
            <p>Загрузка товаров...</p>
        }
        else if (products.Count == 0)
        {
            <p>Товаров пока нет.</p>
        }
        else
        {
            <table class="products-table">
                <thead>
                    <tr>
                        <th>Название</th>
                        <th>Категория</th>
                        <th>Цена</th>
                        <th>Количество</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in products)
                    {
                        <tr>
                            <td>@product.Name</td>
                            <td>@product.Category</td>
                            <td>@product.Price.ToString("0.00") ₽</td>
                            <td>@product.Quantity</td>
                            <td class="actions">
                                <button class="secondary-button" @onclick="() => StartEdit(product)">Изменить</button>
                                <button class="danger-button" @onclick="() => DeleteProductAsync(product)">Удалить</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <div class="card">
        <h2>Добавить товар</h2>

        <EditForm Model="newProduct" OnValidSubmit="CreateProductAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-row">
                <label>Название</label>
                <InputText class="form-control" @bind-Value="newProduct.Name" />
            </div>

            <div class="form-row">
                <label>Категория</label>
                <InputText class="form-control" @bind-Value="newProduct.Category" />
            </div>

            <div class="form-row">
                <label>Цена</label>
                <InputNumber class="form-control" @bind-Value="newProduct.Price" />
            </div>

            <div class="form-row">
                <label>Количество</label>
                <InputNumber class="form-control" @bind-Value="newProduct.Quantity" />
            </div>

            <div class="form-row">
                <label>Описание</label>
                <InputTextArea class="form-control" @bind-Value="newProduct.Description" />
            </div>

            <button class="primary-button" type="submit">Добавить</button>
        </EditForm>
    </div>
</section>

@if (editProduct is not null)
{
    <section class="card edit-card">
        <h2>Изменить товар</h2>

        <EditForm Model="editProduct" OnValidSubmit="UpdateProductAsync">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-row">
                <label>Название</label>
                <InputText class="form-control" @bind-Value="editProduct.Name" />
            </div>

            <div class="form-row">
                <label>Категория</label>
                <InputText class="form-control" @bind-Value="editProduct.Category" />
            </div>

            <div class="form-row">
                <label>Цена</label>
                <InputNumber class="form-control" @bind-Value="editProduct.Price" />
            </div>

            <div class="form-row">
                <label>Количество</label>
                <InputNumber class="form-control" @bind-Value="editProduct.Quantity" />
            </div>

            <div class="form-row">
                <label>Описание</label>
                <InputTextArea class="form-control" @bind-Value="editProduct.Description" />
            </div>

            <div class="action-row">
                <button class="primary-button" type="submit">Сохранить</button>
                <button class="secondary-button" type="button" @onclick="CancelEdit">Отмена</button>
            </div>
        </EditForm>
    </section>
}

@code {
    private readonly List<Product> products = [];
    private Product newProduct = CreateEmptyProduct();
    private Product? editProduct;
    private bool isLoading = true;
    private string? statusMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadProductsAsync();
    }

    private async Task LoadProductsAsync()
    {
        isLoading = true;
        statusMessage = null;

        var items = await Http.GetFromJsonAsync<List<Product>>("api/products");

        products.Clear();
        if (items is not null)
        {
            products.AddRange(items);
        }

        isLoading = false;
    }

    private async Task CreateProductAsync()
    {
        var response = await Http.PostAsJsonAsync("api/products", newProduct);
        if (response.IsSuccessStatusCode)
        {
            newProduct = CreateEmptyProduct();
            statusMessage = "Товар добавлен.";
            await LoadProductsAsync();
        }
    }

    private void StartEdit(Product product)
    {
        editProduct = new Product
        {
            Id = product.Id,
            Name = product.Name,
            Category = product.Category,
            Price = product.Price,
            Quantity = product.Quantity,
            Description = product.Description
        };
    }

    private async Task UpdateProductAsync()
    {
        if (editProduct is null)
        {
            return;
        }

        var response = await Http.PutAsJsonAsync($"api/products/{editProduct.Id}", editProduct);
        if (response.IsSuccessStatusCode)
        {
            editProduct = null;
            statusMessage = "Товар изменен.";
            await LoadProductsAsync();
        }
    }

    private async Task DeleteProductAsync(Product product)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Удалить товар \"{product.Name}\"?");
        if (!confirmed)
        {
            return;
        }

        var response = await Http.DeleteAsync($"api/products/{product.Id}");
        if (response.IsSuccessStatusCode)
        {
            statusMessage = "Товар удален.";
            await LoadProductsAsync();
        }
    }

    private void CancelEdit()
    {
        editProduct = null;
    }

    private static Product CreateEmptyProduct()
    {
        return new Product();
    }
}
