<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PKS4 PR4</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background-color: #f5f7fb; }
        .main-box { background: white; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); }
        .city-photo, .attraction-photo { object-fit: cover; }
        .city-photo { height: 220px; width: 100%; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" asp-controller="Cities" asp-action="Index">Туристический путеводитель</a>
        </div>
    </nav>

    <div class="container py-4">
        <div class="main-box p-4">
            @RenderBody()
        </div>
    </div>
</body>
</html>
