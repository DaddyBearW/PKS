@model List<Product>
@{
    ViewData["Title"] = "Продукты";
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h1 class="h5 mb-3">Добавить продукт</h1>
                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label class="form-label">Название</label>
                        <input name="Name" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Описание</label>
                        <textarea name="Description" class="form-control"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Характеристики</label>
                        <input name="Specifications" class="form-control" value="{}" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Категория</label>
                        <input name="Category" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Минимальный запас</label>
                        <input name="MinimalStock" type="number" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Время на 1 шт. (мин)</label>
                        <input name="ProductionTimePerUnit" type="number" class="form-control" />
                    </div>
                    <button type="submit" class="btn btn-primary">Сохранить</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h5 mb-0">Список продуктов</h2>
            <form method="get" class="d-flex gap-2">
                <select name="category" class="form-select">
                    <option value="">Все категории</option>
                    @foreach (var category in categories)
                    {
                        @if ((string?)ViewBag.Category == category)
                        {
                            <option value="@category" selected>@category</option>
                        }
                        else
                        {
                            <option value="@category">@category</option>
                        }
                    }
                </select>
                <button type="submit" class="btn btn-outline-primary">Фильтр</button>
            </form>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Название</th>
                            <th>Категория</th>
                            <th>Время</th>
                            <th>Материалы</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.Category</td>
                            <td>@item.ProductionTimePerUnit мин</td>
                            <td>@item.ProductMaterials.Count</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Открыть</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
