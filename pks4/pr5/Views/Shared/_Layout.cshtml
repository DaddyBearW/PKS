<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PKS4 PR5</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background: #eef2f7; }
        .page-box { background: white; border-radius: 18px; box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08); }
        .status-badge { padding: 6px 10px; border-radius: 999px; font-size: 13px; }
        .status-pending { background: #fff3cd; }
        .status-progress { background: #cfe2ff; }
        .status-completed { background: #d1e7dd; }
        .status-cancelled { background: #f8d7da; }
        .status-active { background: #d1e7dd; }
        .status-stopped { background: #f8d7da; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">Производство</a>
            <div class="navbar-nav">
                <a class="nav-link" asp-controller="Materials" asp-action="Index">Материалы</a>
                <a class="nav-link" asp-controller="Products" asp-action="Index">Продукты</a>
                <a class="nav-link" asp-controller="Orders" asp-action="Index">Заказы</a>
                <a class="nav-link" asp-controller="Lines" asp-action="Index">Линии</a>
            </div>
        </div>
    </nav>

    <div class="container py-4">
        <div class="page-box p-4">
            @if (TempData["Message"] != null)
            {
                <div class="alert alert-info">@TempData["Message"]</div>
            }

            @RenderBody()
        </div>
    </div>
</body>
</html>
