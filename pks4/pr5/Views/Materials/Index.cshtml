@model List<Material>
@{
    ViewData["Title"] = "Материалы";
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h1 class="h5 mb-3">Добавить материал</h1>
                <form asp-action="Add" method="post">
                    <div class="mb-3">
                        <label class="form-label">Название</label>
                        <input name="Name" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Количество</label>
                        <input name="Quantity" type="number" step="0.01" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ед. измерения</label>
                        <input name="UnitOfMeasure" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Минимальный запас</label>
                        <input name="MinimalStock" type="number" step="0.01" class="form-control" />
                    </div>
                    <button type="submit" class="btn btn-primary">Сохранить</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h2 class="h5 mb-3">Склад материалов</h2>
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Название</th>
                            <th>Количество</th>
                            <th>Ед.</th>
                            <th>Пополнение</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model)
                    {
                        var lowStock = item.Quantity <= item.MinimalStock;
                        <tr class="@(lowStock ? "table-warning" : string.Empty)">
                            <td>@item.Name</td>
                            <td>@item.Quantity</td>
                            <td>@item.UnitOfMeasure</td>
                            <td>
                                <form asp-action="Restock" method="post" class="d-flex gap-2">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="number" name="amount" step="0.01" value="10" class="form-control form-control-sm" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">Пополнить</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
